{
  "id": "sourceBridge",
  "type": "text",
  "title": {
    "zh": "信息源桥接",
    "en": "Source bridge"
  },
  "valueTemplate": {
    "zh": "BBC聚焦：{truncate:sourceHeadline|48}",
    "en": "BBC focus: {truncate:sourceHeadline|48}"
  },
  "subTemplate": {
    "zh": "条目数 {sourceCount} ｜ 国家 {default:sourceCountry|'暂无'}",
    "en": "Count {sourceCount} | Country {default:sourceCountry|'N/A'}"
  },
  "externalSources": [
    {
      "key": "sourceHeadline",
      "sourceApi": "BBC World",
      "responseType": "json",
      "path": "items.0.title",
      "ttlSeconds": 300
    },
    {
      "key": "sourceCountry",
      "sourceApi": "BBC World",
      "responseType": "json",
      "path": "items.0.country",
      "ttlSeconds": 300
    },
    {
      "key": "sourceCount",
      "sourceApi": "BBC World",
      "responseType": "json",
      "path": "count",
      "ttlSeconds": 300
    }
  ],
  "functions": [
    "truncate",
    "default"
  ]
}
